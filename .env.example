# Concord Environment Variables copy to .env and fill in values

# LLM Backend 
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Database
POSTGRES_URL=postgresql://concord:concord@localhost:5432/concord
REDIS_URL=redis://localhost:6379

# Webhook secret (GitHub / GitLab)
WEBHOOK_SECRET=

# Per-connector scoped tokens (one per connector in tools.yaml)
TERRASECURE_TOKEN=
TRIVY_TOKEN=
CHECKOV_TOKEN=
KAGENT_TOKEN=
HOLMESGPT_TOKEN=
